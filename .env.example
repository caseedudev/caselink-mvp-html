# ============================================================
# CaseLink MVP - LLM Provider Configuration
# 이 파일을 .env 로 복사하여 사용하세요
# ============================================================

# ── Anthropic (Claude) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODELS=claude-sonnet-4-5-20250514,claude-haiku-4-5-20250414,claude-3-5-haiku-20241022

# ── Google Gemini ───────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash-preview-05-20,gemini-2.5-pro-preview-05-06,gemini-2.0-flash

# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODELS=gpt-4.1,gpt-4.1-mini,gpt-4.1-nano,gpt-4o,gpt-4o-mini,o4-mini

# ── Z.ai CodingPlan ────────────────────────────────
ZAI_API_KEY=
ZAI_MODELS=codingplan
