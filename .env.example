# ============================================================
# CaseLink MVP - LLM Provider Configuration
# 이 파일을 .env 로 복사하여 사용하세요
# ============================================================

# ── Anthropic (Claude) ──────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-haiku-4-5

# ── Google Gemini ───────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-3.1-pro-preview,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5.4-nano,gpt-5.2,gpt-5.1,gpt-5-mini,gpt-5-nano

# ── Z.ai CodingPlan ────────────────────────────────
Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=
ZAI_MODELS=glm-5.1glm-5,glm-4.7,glm-4.6v,glm-4.6v-flash,glm-4.5-Air